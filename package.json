{
  "name": "worldpool",
  "version": "0.1.0",
  "description": "Global proxy pool. Self-maintaining, free, open.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "pipeline": "tsx src/pipeline.ts",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
